<header class="absolute w-full z-50 text-white">

<nav class="flex justify-between items-center px-6 py-6 md:px-24">

<img src="/images/logo.svg" class="h-6">

<ul class="hidden md:flex gap-8">

<li>About</li>
<li>Careers</li>
<li>Events</li>
<li>Products</li>
<li>Support</li>

</ul>

<button id="menuBtn" class="md:hidden">

<img src="/images/icon-hamburger.svg">

</button>

</nav>


<div id="mobileMenu" class="fixed inset-0 bg-black text-white hidden flex-col p-6">

<div class="flex justify-between items-center">

<img src="/images/logo.svg">

<button id="closeMenu">
<img src="/images/icon-close.svg">
</button>

</div>

<ul class="flex flex-col gap-8 text-3xl mt-24 font-[Josefin_Sans]">

<li>ABOUT</li>
<li>CAREERS</li>
<li>EVENTS</li>
<li>PRODUCTS</li>
<li>SUPPORT</li>

</ul>

</div>


<script>

const btn = document.getElementById("menuBtn")
const close = document.getElementById("closeMenu")
const menu = document.getElementById("mobileMenu")

btn.onclick = () => {
menu.classList.remove("hidden")
menu.classList.add("flex")
}

close.onclick = () => {
menu.classList.add("hidden")
menu.classList.remove("flex")
}

</script>

</header>